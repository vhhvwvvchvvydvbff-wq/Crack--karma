settingsTab:AddSwitch("Wild Wizard (PERMA)", function()

    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local RunService = game:GetService("RunService")

    local LocalPlayer = Players.LocalPlayer
    local MAX_EQUIP = 8
    local PET_NAME = "Wild Wizard"

    local reequipping = false
    local lastEquip = 0
    local COOLDOWN = 1

    local function forceEquipWildWizard()
        if reequipping then return end
        if tick() - lastEquip < COOLDOWN then return end

        reequipping = true
        lastEquip = tick()

        local petsFolder = LocalPlayer:FindFirstChild("petsFolder")
        if not petsFolder then
            reequipping = false
            return
        end

        local equipped = 0

        -- Contar los Wild Wizard equipados
        for _, folder in pairs(petsFolder:GetChildren()) do
            if folder:IsA("Folder") then
                for _, pet in pairs(folder:GetChildren()) do
                    if pet.Name == PET_NAME and pet:FindFirstChild("equipped") and pet.equipped.Value == true then
                        equipped += 1
                    end
                end
            end
        end

        -- Equipar los que falten
        if equipped < MAX_EQUIP then
            for _, folder in pairs(petsFolder:GetChildren()) do
                if folder:IsA("Folder") then
                    for _, pet in pairs(folder:GetChildren()) do
                        if pet.Name == PET_NAME then
                            ReplicatedStorage.rEvents.equipPetEvent:FireServer("equipPet", pet)
                            equipped += 1
                            if equipped >= MAX_EQUIP then break end
                        end
                    end
                end
                if equipped >= MAX_EQUIP then break end
            end
        end

        reequipping = false
    end

    -- LOOP ANTI-DESEQUIP
    RunService.Heartbeat:Connect(function()
        forceEquipWildWizard()
    end)

    -- AL MORIR / RESPAWN
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(1)
        forceEquipWildWizard()
    end)

    print("🔥 Wild Wizard PERMA-EQUIP ACTIVADO 🔥")

end)


