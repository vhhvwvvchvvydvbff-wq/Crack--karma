                            firetouchinterest(RH, root, 1)
                            firetouchinterest(LH, root, 1)
                            firetouchinterest(RH, root, 0)
                            firetouchinterest(LH, root, 0)
                        end)
                    end
                end
            end

            task.wait(0.05)
        end
    end)
