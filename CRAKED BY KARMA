	if row then
		row:Destroy()
		rows[plr.UserId] = nil
	end
end

-----------------------------------------------------
-- 🔄 ACTUALIZAR TEXTO (SIN CREAR FILAS)
-----------------------------------------------------
local function updateRows()
	for _, plr in ipairs(Players:GetPlayers()) do
		ensureRow(plr)

		local row = rows[plr.UserId]
		local char = plr.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		local leader = plr:FindFirstChild("leaderstats")

		local hp = hum and hum.Health or 0
		local str = leader and leader:FindFirstChild("Strength") and leader.Strength.Value or "N/A"

		row.Text = string.format(
			"  %s   ❤️ %s | 💪 %s",
			plr.DisplayName,
			formatNum(hp),
			type(str) == "number" and formatNum(str) or str
		)
	end
end

