        {"Pushups", "repTime", State and 0 or 1},
        {"Weight", "repTime", State and 0 or 1},
        {"Situps", "repTime", State and 0 or 1}
    }

    -- Ajustar todas las herramientas de Fast Tools
    for _, toolInfo in ipairs(toolSettings) do
        local toolName, propName, value = unpack(toolInfo)

        local tool = backpack:FindFirstChild(toolName)
        if tool and tool:FindFirstChild(propName) then
            tool[propName].Value = value
        end

        local equippedTool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(toolName)
        if equippedTool and equippedTool:FindFirstChild(propName) then
            equippedTool[propName].Value = value
        end
    end

    -- Auto Punch
    if State then
        task.spawn(function()
            while _G.fastHitActive do
                local punch = LocalPlayer.Backpack:FindFirstChild("Punch")
                if punch then
                    punch.Parent = LocalPlayer.Character
                    if punch:FindFirstChild("attackTime") then
                        punch.attackTime.Value = 0
                    end
                end
                task.wait(0.1)
            end
        end)

        task.spawn(function()
            while _G.fastHitActive do
                local punch = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Punch")
                if punch then
                    punch:Activate()
                end
                task.wait(0.1)
            end
        end)
    else
        local punch = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Punch")
        if punch then
            punch.Parent = LocalPlayer.Backpack
        end
    end

    -- Kill Target Loop
    task.spawn(function()
        while killTarget do
            local punch = LocalPlayer.Backpack:FindFirstChild("Punch")
            local char = LocalPlayer.Character

            if punch and not char:FindFirstChild("Punch") then
                punch.Parent = char
            end

