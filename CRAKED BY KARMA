    CloseBtn.Size = UDim2.new(0, 30, 0, 30)
    CloseBtn.Position = UDim2.new(1, -35, 0.5, -15)
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.Text = "X"
    CloseBtn.TextColor3 = Color3.fromRGB(255, 0, 110)
    CloseBtn.TextSize = 25
    CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    local Scroll = Instance.new("ScrollingFrame", MainFrame)
    Scroll.Size = UDim2.new(1, -20, 1, -60)
    Scroll.Position = UDim2.new(0, 10, 0, 55)
    Scroll.BackgroundTransparency = 1
    Scroll.ScrollBarThickness = 2
    Scroll.CanvasSize = UDim2.new(0, 0, 0, 550)

    local Layout = Instance.new("UIListLayout", Scroll)
    Layout.Padding = UDim.new(0, 8)

    local function CreateLabel(text, color, size, font)
        local lbl = Instance.new("TextLabel", Scroll)
        lbl.Size = UDim2.new(1, 0, 0, 22)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3 = color or Color3.fromRGB(255, 255, 255)
        lbl.Font = font or Enum.Font.Code
        lbl.TextSize = size or 17
        lbl.Text = text
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextWrapped = true
        return lbl
    end

    -----------------------------------------------------
    -- 🕒 ETIQUETAS (SEGÚN TU GUION)
    -----------------------------------------------------
    local stopwatchLabel = CreateLabel("⏱ Tiempo de Repetición: 0d 0h 0m 0s", Color3.fromRGB(0, 255, 255), 17)
    local projStrengthLabel = CreateLabel("Fuerza: 0/Hora | 0/Día | 0/Semana | 0/Mes", Color3.fromRGB(200, 200, 200), 12)
    local projDurabilityLabel = CreateLabel("Dura: 0/Hora | 0/Día | 0/Semana | 0/Mes", Color3.fromRGB(200, 200, 200), 12)
    local projRebirthLabel = CreateLabel("Rebirth: 0/Hora | 0/Día | 0/Semana | 0/Mes", Color3.fromRGB(200, 200, 200), 12)
    
    CreateLabel("━━━━━━━━━━━━━━━━━━━━━━", Color3.fromRGB(100, 100, 100))
    local welcomeLabel = CreateLabel("Acceso HABILITADO! Bienvenido.", Color3.fromRGB(0, 255, 150), 17)
    CreateLabel("━━━━━━━━━━━━━━━━━━━━━━", Color3.fromRGB(100, 100, 100))

    local strengthLabel = CreateLabel("Fuerza: 0 | Ganado: 0", Color3.fromRGB(255, 255, 255), 16)
    local durabilityLabel = CreateLabel("Durabilidad: 0 | Ganado: 0", Color3.fromRGB(255, 255, 255), 16)
    local rebirthLabel = CreateLabel("Rebirths: 0 | Ganado: 0", Color3.fromRGB(255, 255, 255), 16)

    -----------------------------------------------------
    -- ⏱ LÓGICA DE CRONÓMETRO Y CÁLCULOS (TU GUION INTACTO)
    -----------------------------------------------------
    local startTime = tick()
    local initialStrength = strengthStat.Value
    local initialDurability = durabilityStat.Value
    local initialRebirths = rebirthStat.Value
    local trackingStarted = false

    local strengthHistory = {}
    local durabilityHistory = {}
    local rebirthHistory = {}
    local calculationInterval = 10

    task.spawn(function()
        local lastCalcTime = tick()
        while task.wait(0.2) and ScreenGui.Parent do
            local currentTime = tick()
            local currentStrength = strengthStat.Value
            local currentDurability = durabilityStat.Value
            local currentRebirths = rebirthStat.Value

            if not trackingStarted then
                if currentStrength > initialStrength or currentDurability > initialDurability or currentRebirths > initialRebirths then
                    trackingStarted = true
                    startTime = currentTime
                    strengthHistory = {}
                    durabilityHistory = {}
                    rebirthHistory = {}
                    welcomeLabel.Text = "ESTADO: ESCANEANDO ACTIVIDAD..."
                end
            end

            if trackingStarted then
                local elapsed = currentTime - startTime
                local d = math.floor(elapsed / 86400)
                local h = math.floor((elapsed % 86400) / 3600)
                local m = math.floor((elapsed % 3600) / 60)
                local s = math.floor(elapsed % 60)
                stopwatchLabel.Text = string.format("⏱ Tiempo de Repetición: %dd %dh %dm %ds", d, h, m, s)

                local strengthGain = currentStrength - initialStrength
                local durabilityGain = currentDurability - initialDurability
                local rebirthGain = currentRebirths - initialRebirths

                strengthLabel.Text = "Fuerza: " .. formatNumber(currentStrength) .. " | Ganado: " .. formatNumber(strengthGain)
                durabilityLabel.Text = "Durabilidad: " .. formatNumber(currentDurability) .. " | Ganado: " .. formatNumber(durabilityGain)
                rebirthLabel.Text = "Rebirths: " .. formatNumber(currentRebirths) .. " | Ganado: " .. formatNumber(rebirthGain)

                table.insert(strengthHistory, {time = currentTime, value = currentStrength})
                table.insert(durabilityHistory, {time = currentTime, value = currentDurability})
                table.insert(rebirthHistory, {time = currentTime, value = currentRebirths})

                while #strengthHistory > 0 and currentTime - strengthHistory[1].time > calculationInterval do table.remove(strengthHistory, 1) end
                while #durabilityHistory > 0 and currentTime - durabilityHistory[1].time > calculationInterval do table.remove(durabilityHistory, 1) end
                while #rebirthHistory > 0 and currentTime - rebirthHistory[1].time > calculationInterval do table.remove(rebirthHistory, 1) end

                if currentTime - lastCalcTime >= calculationInterval then
                    lastCalcTime = currentTime
                    
                    local function updateProjection(hist, label, prefix)
                        if #hist >= 2 then
                            local delta = hist[#hist].value - hist[1].value
                            local perSec = delta / calculationInterval
                            label.Text = string.format("%s: %s/Hora | %s/Dia | %s/Semana | %s/Mes", prefix, formatNumber(perSec * 3600), formatNumber(perSec * 86400), formatNumber(perSec * 604800), formatNumber(perSec * 2592000))
                        end
                    end
                    updateProjection(strengthHistory, projStrengthLabel, "Fuerza")
                    updateProjection(durabilityHistory, projDurabilityLabel, "Durabilidad")
                    updateProjection(rebirthHistory, projRebirthLabel, "Rebirth")
                end
            end
        end
    end)

    -- ARRASTRE DEL PANEL
    local dragging, dragStart, startPos
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true dragStart = input.Position startPos = MainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input) dragging = false end)
end)

