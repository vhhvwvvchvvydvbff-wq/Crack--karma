    local function formatAbbreviated(number)
        local abbreviations = {"", "K", "M", "B", "T", "Qa", "Qi"}
        local index = 1
        while tonumber(number) and number >= 1000 and index < #abbreviations do
            number = number / 1000
            index = index + 1
        end
        return string.format("%.2f", tonumber(number) or 0) .. abbreviations[index]
