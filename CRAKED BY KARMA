-- Update Search
local function updateSearch(query)
    if currentView ~= "all" then return end
    query = string.lower(query)
    for _, data in pairs(emoteItems) do
        local visible = query == "" or string.find(data.name, query, 1, true)
        data.frame.Visible = visible
    end
end

-- Switch View
local function switchView(view)
    currentView = view
    emoteScrollingFrame.Visible = (view == "all")
    favoritesScrollingFrame.Visible = (view == "favorites")
end

-- Fetch Emotes
local function fetchEmotes()
    fetchedEmotes = 0
    progressBar.Visible = true
    progressFill.Size = UDim2.new(0, 0, 1, 0)
    progressText.Text = "0%"

    while true do
        local success, response = pcall(function()
            return game:HttpGetAsync("https://catalog.roblox.com/v1/search/items/details?Category=12&Subcategory=39&limit=30&IncludeNotForSale=true&cursor=" .. Cursor)
        end)
        if not success then
            task.wait(5)
            continue
        end

        local dataSuccess, data = pcall(function()
            return HttpService:JSONDecode(response)
        end)
        if not dataSuccess or not data.data then
            task.wait(2)
            continue
        end

        for _, v in pairs(data.data) do
            AddEmote(v.name, v.id)
        end
        Cursor = data.nextPageCursor or ""
        if not Cursor then break end
    end

    updateProgress()
    sendNotif("HonnyDezz", "All emotes loaded! Favorites are available.", "")
end

