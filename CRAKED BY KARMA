        local HumanoidRootPart = character:WaitForChild("HumanoidRootPart") 

        -- Limpiamos cualquier GUI antigua que pudiera quedar
        local oldGui = HumanoidRootPart:FindFirstChild("OMEGADEZZ_ESP")
        if oldGui then oldGui:Destroy() end

        local BillboardGui = Instance.new("BillboardGui", HumanoidRootPart)
        BillboardGui.Name = "OMEGADEZZ_ESP"
        BillboardGui.Size = UDim2.new(0,200,0,50)
        BillboardGui.AlwaysOnTop = true

        local Text = Instance.new("TextLabel", BillboardGui)
        Text.Size = UDim2.new(1,0,1,0)
        Text.BackgroundTransparency = 1
        Text.TextColor3 = Color3.new(1,0,0)
        Text.TextStrokeTransparency = 0.5
        Text.Font = Enum.Font.GothamBold
        Text.TextScaled = true

        local hum = character:FindFirstChildOfClass("Humanoid")
        -- leaderstats se mantiene en el Player, no en el Character, por eso lo buscamos aquí:
        local strengthStat = plr:FindFirstChild("leaderstats") and plr.leaderstats:FindFirstChild("Strength")

        -- Conexión de RenderStepped para actualizar stats
        local conn = game:GetService("RunService").RenderStepped:Connect(function()
            if not ESPEnabled or not character or not hum then return end

            local hp = hum.Health
            local str = strengthStat and strengthStat.Value or 0

            Text.Text = string.format("%s\nDurability: %s | Strength: %s", plr.DisplayName, formatNum(hp), formatNum(str))
        end)
        
        -- Guardamos la conexión de RenderStepped y la GUI actual
        if espConnections[plr] and espConnections[plr].conn then 
             espConnections[plr].conn:Disconnect() 
        end
        
        -- Actualizamos las conexiones/GUI en la tabla
        espConnections[plr] = espConnections[plr] or {}
        espConnections[plr].gui = BillboardGui
        espConnections[plr].conn = conn
    end

    -- 2. Aseguramos la conexión CharacterAdded para el respawn futuro
    -- Si ya existe, la desconectamos para evitar duplicados
    if espConnections[plr] and espConnections[plr].charConn then 
        espConnections[plr].charConn:Disconnect() 
    end
    
    -- Creamos una nueva conexión para CharacterAdded
    local charAddedConn = plr.CharacterAdded:Connect(setupGui)
    
    -- Guardamos la conexión CharacterAdded
    espConnections[plr] = espConnections[plr] or {}
    espConnections[plr].charConn = charAddedConn

    -- 3. Si el personaje ya existe (al inicio del juego o si ya respawneó), lo configuramos inmediatamente
    if plr.Character then
        setupGui(plr.Character)
    end
end

