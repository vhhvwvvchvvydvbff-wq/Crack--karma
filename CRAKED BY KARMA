local function enablePanel()
	if panelEnabled then return end
	panelEnabled = true

	createPanel()
	slideIn()
	updateRows()

	updateConn = RunService.RenderStepped:Connect(updateRows)
end

local function disablePanel()
	if not panelEnabled then return end
	panelEnabled = false

	slideOut()

	if updateConn then
		updateConn:Disconnect()
		updateConn = nil
	end
end

