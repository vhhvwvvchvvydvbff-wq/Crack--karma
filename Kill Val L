local function saveLists()
    if writefile then
        pcall(function()
            writefile("AutoKill_Whitelist.json", HttpService:JSONEncode(State.Whitelist))
            writefile("AutoKill_Blacklist.json", HttpService:JSONEncode(State.Blacklist))
            
            -- NUEVO: Guardar el estado de los botones
            local settings = {
                AutoKillEnabled = State.AutoKillEnabled,
                AutoKillAll = State.AutoKillAll,
                AntiAFK = State.AntiAFK,
                Notificaciones = State.Notificaciones,
                AtaqueRapido = State.AtaqueRapido,
                FriendsWhitelist = State.FriendsWhitelist,
                LockPosition = State.LockPosition,
                NewServer = State.NewServer,
                VerVida = State.VerVida
            }
            writefile("AutoKill_Settings.json", HttpService:JSONEncode(settings))
        end)
    end
end

local function loadLists()
    if isfile and readfile then
        pcall(function()
            if isfile("AutoKill_Whitelist.json") then
                State.Whitelist = HttpService:JSONDecode(readfile("AutoKill_Whitelist.json")) or {}
            end
            if isfile("AutoKill_Blacklist.json") then
                State.Blacklist = HttpService:JSONDecode(readfile("AutoKill_Blacklist.json")) or {}
            end
            
            -- NUEVO: Cargar el estado de los botones
            if isfile("AutoKill_Settings.json") then
                local savedSettings = HttpService:JSONDecode(readfile("AutoKill_Settings.json"))
                if savedSettings then
                    if savedSettings.AutoKillEnabled ~= nil then State.AutoKillEnabled = savedSettings.AutoKillEnabled end
                    if savedSettings.AutoKillAll ~= nil then State.AutoKillAll = savedSettings.AutoKillAll end
                    if savedSettings.AntiAFK ~= nil then State.AntiAFK = savedSettings.AntiAFK end
                    if savedSettings.Notificaciones ~= nil then State.Notificaciones = savedSettings.Notificaciones end
                    if savedSettings.AtaqueRapido ~= nil then State.AtaqueRapido = savedSettings.AtaqueRapido end
                    if savedSettings.FriendsWhitelist ~= nil then State.FriendsWhitelist = savedSettings.FriendsWhitelist end
                    if savedSettings.LockPosition ~= nil then State.LockPosition = savedSettings.LockPosition end
                    if savedSettings.NewServer ~= nil then State.NewServer = savedSettings.NewServer end
                    if savedSettings.VerVida ~= nil then State.VerVida = savedSettings.VerVida end
                end
            end
        end)
    end
end
