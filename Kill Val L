    local linkLista = string.char(104, 116, 116, 112, 115, 58, 47, 47, 112, 97, 115, 116, 101, 98, 105, 110, 46, 99, 111, 109, 47, 114, 97, 119, 47, 84, 56, 84, 97, 74, 69, 50, 89) 
    
