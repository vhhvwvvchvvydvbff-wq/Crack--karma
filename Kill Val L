-- ================== SISTEMA DE LOCK POSITION ==================
task.spawn(function()
    while task.wait(0.5) do -- Revisa cada medio segundo
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        if State.LockPosition then
            if root and hum and hum.Health > 0 then
                -- 1. Si no hay posición guardada, guarda tu lugar actual
                if not State.SavedPosition then
                    State.SavedPosition = root.CFrame
                end
                
                -- 2. Anclar el personaje para que NADIE pueda empujarlo
                if not root.Anchored then
                    root.Anchored = true
                end
                
                -- 3. Si reapareciste muy lejos (te mataron), te teletransporta de vuelta
                if (root.Position - State.SavedPosition.Position).Magnitude > 10 then
                    root.CFrame = State.SavedPosition
                end
            end
        else
            -- Si apagas el botón: borra la posición y te desancla para que puedas moverte
            if State.SavedPosition then
                State.SavedPosition = nil
                if root then
                    root.Anchored = false
                end
            end
        end
    end
end)

-- ================== SISTEMA DE AUTO NEW SERVER ==================
local TeleportService = game:GetService("TeleportService")

task.spawn(function()
    while task.wait(10) do -- Revisa cada 10 segundos para no saturar el juego
        -- Si el botón está activo y hay 5 jugadores o menos en tu servidor
        if State.NewServer and #Players:GetPlayers() <= 5 then
            
            -- Avisamos en pantalla
            StarterGui:SetCore("SendNotification", {
                Title = "¡Pocos Jugadores!",
                Text = "Buscando un servidor más lleno...",
                Duration = 5
            })
            
            pcall(function()
                -- Buscamos la lista de servidores de este juego usando la API de Roblox
                local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
                local response = game:HttpGet(url)
                local data = HttpService:JSONDecode(response)
                
                if data and data.data then
                    for _, server in ipairs(data.data) do
                        -- Elegir un servidor diferente que tenga MÁS de 5 personas y no esté lleno
                        if server.id ~= game.JobId and server.playing > 5 and server.playing < server.maxPlayers then
                            TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                            break
                        end
                    end
                end
            end)
            
            -- Esperamos un poco para darle tiempo a teletransportarse
            task.wait(15)
        end
    end
end)

-- ================== HELPER: LISTA DE JUGADORES ==================
local function getPlayerList()
    local list = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            -- Formato exacto de la imagen: Apodo | Usuario
            local entry = player.DisplayName .. " | " .. player.Name
            table.insert(list, entry)
        end
    end
    if #list == 0 then
        table.insert(list, "Sin jugadores en el servidor")
    end
    return list
end
