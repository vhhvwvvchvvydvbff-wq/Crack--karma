local function isWhitelisted(plr)
    -- Si el botón está activado, verifica si son amigos en Roblox
    if State.FriendsWhitelist then
        -- pcall para evitar errores si el servidor de Roblox tarda en responder
        local success, isFriend = pcall(function()
            return LocalPlayer:IsFriendsWith(plr.UserId)
        end)
        if success and isFriend then return true end
    end

    -- Lógica normal: revisa la lista escrita en el Hub
    for _, name in ipairs(State.Whitelist) do
        if plr.Name:lower() == name:lower() then return true end
    end
    return false
end


local function isBlacklisted(plr)
    for _, name in ipairs(State.Blacklist) do
        if plr.Name:lower() == name:lower() then return true end
    end
    return false
end

local function equipPunch()
    if not LocalPlayer.Character then return false end
    local char = LocalPlayer.Character
    if char:FindFirstChild("Punch") then return true end
    local backpack = LocalPlayer.Backpack
    local punch = backpack:FindFirstChild("Punch")
    if punch then
        punch.Parent = char
        return true
    end
    return false
end

local function getValidTargets()
    local targets = {}
    local targetAdded = {}

    local function addTarget(player)
        if targetAdded[player] then return end
        local char = player.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if humanoid and root and humanoid.Health > 0 then
                targetAdded[player] = true
                table.insert(targets, { Player = player, Character = char, Humanoid = humanoid, RootPart = root })
            end
        end
    end

    if State.AutoKillAll then
        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer or isWhitelisted(player) then continue end
            addTarget(player)
        end
    elseif State.TargetPlayerName ~= "" then
        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer or not player.Name:lower():find(State.TargetPlayerName:lower()) then continue end
            addTarget(player)
            break
        end
    end

    return targets
end

-- ================== AUTO KILL PRINCIPAL ==================
local function startAutoKill()
    if State.AttackConnection then State.AttackConnection:Disconnect() end

    State.AttackConnection = RunService.Heartbeat:Connect(function()
        if not State.AutoKillEnabled or not LocalPlayer.Character then return end
        
        local speed = State.AtaqueRapido and 0.01 or 0.03
        if tick() - State.AttackTick < speed then return end
        State.AttackTick = tick()

        if not equipPunch() then return end
        
        local myChar = LocalPlayer.Character
        local leftHand = myChar:FindFirstChild("LeftHand")
        local rightHand = myChar:FindFirstChild("RightHand")

        if not leftHand and not rightHand then return end

        local targets = getValidTargets()
        if #targets == 0 then return end -- Si no hay a quién pegarle, no hace nada

        -- MEJORA 1: Enviamos la señal al servidor UNA SOLA VEZ por cada ciclo
        pcall(function()
            LocalPlayer.muscleEvent:FireServer("punch", "leftHand")
            LocalPlayer.muscleEvent:FireServer("punch", "rightHand")
        end)

        -- Atacamos a todos simultáneamente sin pausas (MEJORA 2)
        for _, target in ipairs(targets) do
            if leftHand then
                pcall(function()
                    firetouchinterest(leftHand, target.RootPart, 0)
                    firetouchinterest(leftHand, target.RootPart, 1)
                end)
            end
            if rightHand then
                pcall(function()
                    firetouchinterest(rightHand, target.RootPart, 0)
                    firetouchinterest(rightHand, target.RootPart, 1)
                end)
            end
        end
    end)
end

local function stopAutoKill()
    if State.AttackConnection then
        State.AttackConnection:Disconnect()
        State.AttackConnection = nil
    end
end

-- ================== BLACKLIST INDEPENDIENTE ==================
local BlacklistConnection = nil
local BlacklistAttackTick = tick()
local NotifiedPlayers = {}

local function startBlacklistKill()
    if BlacklistConnection then BlacklistConnection:Disconnect() end
    
    BlacklistConnection = RunService.Heartbeat:Connect(function()
        if not LocalPlayer.Character then return end
        
        local speed = State.AtaqueRapido and 0.01 or 0.03
        if tick() - BlacklistAttackTick < speed then return end
        BlacklistAttackTick = tick()
        
        local hasBlacklistedTarget = false
        
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and isBlacklisted(player) then
                
                if State.Notificaciones and not NotifiedPlayers[player.UserId] then
                    NotifiedPlayers[player.UserId] = true
                    StarterGui:SetCore("SendNotification", {
                        Title = "¡Blacklist Detectada!",
                        Text = "Atacando a: " .. player.Name,
                        Duration = 3
                    })
                end

                local char = player.Character
                if char and char:FindFirstChild("HumanoidRootPart") and char.Humanoid.Health > 0 then
                    hasBlacklistedTarget = true
                    
                    if equipPunch() then
                        local myChar = LocalPlayer.Character
                        local lHand = myChar:FindFirstChild("LeftHand")
                        local rHand = myChar:FindFirstChild("RightHand")
                        
                        pcall(function()
                            if lHand then
                                firetouchinterest(lHand, char.HumanoidRootPart, 0)
                                firetouchinterest(lHand, char.HumanoidRootPart, 1)
                            end
                            if rHand then
                                firetouchinterest(rHand, char.HumanoidRootPart, 0)
                                firetouchinterest(rHand, char.HumanoidRootPart, 1)
                            end
                        end)
                    end
                end
            end
        end
        
        -- Igual que arriba, solo disparamos el evento de servidor si realmente hay alguien a quien pegarle
        if hasBlacklistedTarget then
            pcall(function()
                LocalPlayer.muscleEvent:FireServer("punch", "leftHand")
                LocalPlayer.muscleEvent:FireServer("punch", "rightHand")
            end)
        end
    end)
end

-- ================== SISTEMA DE ESP (VER VIDA) ==================
task.spawn(function()
    local suffixes = {
        {"Qi", 1e18}, {"Qa", 1e15}, {"T",  1e12},
        {"B",  1e9},  {"M",  1e6},  {"K",  1e3}
    }

    local function formatNumber(n)
        for _, s in ipairs(suffixes) do
            if n >= s[2] then return string.format("%.2f%s", n / s[2], s[1]) end
        end
        return tostring(math.floor(n))
    end

    local function createBillboard(humanoid, character)
        if not character:FindFirstChild("Head") then return end
        local old = character.Head:FindFirstChild("HP_BILLBOARD")
        if old then old:Destroy() end

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "HP_BILLBOARD"
        billboard.Size = UDim2.new(6, 0, 1.2, 0)
        billboard.StudsOffset = Vector3.new(0, 3.5, 0)
        billboard.AlwaysOnTop = true
        billboard.MaxDistance = 500
        billboard.Enabled = State.VerVida
        billboard.Parent = character.Head

        local frame = Instance.new("Frame")
        frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        frame.BackgroundTransparency = 0.3
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.BorderSizePixel = 0
        frame.Parent = billboard

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = frame

        local bar = Instance.new("Frame")
        bar.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
        bar.Size = UDim2.new(1, 0, 1, 0)
        bar.BorderSizePixel = 0
        bar.Parent = frame

        local gradient = Instance.new("UIGradient")
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
        })
        gradient.Parent = bar

        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 2
        stroke.Color = Color3.fromRGB(0, 0, 0)
        stroke.Transparency = 0.7
        stroke.Parent = bar

        local label = Instance.new("TextLabel")
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(1, 0, 1, 0)
        label.TextColor3 = Color3.new(1, 1, 1)
        label.Font = Enum.Font.GothamBold
        label.TextSize = 18
        label.TextStrokeTransparency = 0.5
        label.Parent = frame

        local textConstraint = Instance.new("UITextSizeConstraint")
        textConstraint.MaxTextSize = 24
        textConstraint.MinTextSize = 14
        textConstraint.Parent = label

        local function updateHP()
            if humanoid and humanoid.Parent then
                local hp = humanoid.Health
                local max = humanoid.MaxHealth
                if max > 0 then
                    bar.Size = UDim2.new(math.clamp(hp / max, 0, 1), 0, 1, 0)
                end
                label.Text = formatNumber(hp) .. " / " .. formatNumber(max)
            end
        end

        humanoid.HealthChanged:Connect(updateHP)
        updateHP()
    end

    local function onCharacterAdded(character)
        local humanoid = character:WaitForChild("Humanoid", 3)
        if humanoid then createBillboard(humanoid, character) end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then onCharacterAdded(plr.Character) end
        plr.CharacterAdded:Connect(function(char) if plr ~= LocalPlayer then onCharacterAdded(char) end end)
    end
    Players.PlayerAdded:Connect(function(plr)
        plr.CharacterAdded:Connect(function(char) if plr ~= LocalPlayer then onCharacterAdded(char) end end)
    end)
end) 
 
    
    


